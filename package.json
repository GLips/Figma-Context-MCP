{
  "name": "figma-developer-mcp",
  "version": "0.1.8",
  "description": "Model Context Protocol server for Figma integration",
  "main": "dist/index.js",
  "bin": {
    "figma-developer-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
    "type-check": "tsc --noEmit",
    "start": "webpack serve --open",
    "start:cli": "cross-env NODE_ENV=cli node dist/index.js",
    "start:http": "node dist/index.js",
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "dev:cli": "cross-env NODE_ENV=development tsx watch src/index.ts --stdio",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "inspect": "pnpx @modelcontextprotocol/inspector",
    "prepare": "pnpm run build && chmod +x ./dist/cli.js",
    "pub:release": "pnpm build && npm publish",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GLips/Figma-Context-MCP.git"
  },
  "keywords": [
    "figma",
    "mcp",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "@phosphor-icons/react": "^2.1.10",
    "@types/yargs": "^17.0.33",
    "axios": "^1.7.9",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "framer-motion": "^12.6.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remeda": "^2.21.2",
    "styled-components": "^6.1.16",
    "yargs": "^17.7.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@figma/rest-api-spec": "^0.24.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@types/styled-components": "^5.1.34",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "html-webpack-plugin": "^5.6.3",
    "jest": "^29.7.0",
    "prettier": "^3.5.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  }
}
